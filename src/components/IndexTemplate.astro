---
// src/components/IndexTemplate.astro
import { indexContent, logos } from "../data/indexContent";

const { pathname } = Astro.url;
const lang = pathname.startsWith("/en") ? "en" : "es";
const t = indexContent[lang];
---

<div class="index-layout">
  <div class="index-bio">
    <p set:html={t.bio} />
  </div>

  <div class="index-tools">
    <p class="tools-title">{t.toolsTitle}</p>
    <div class="tools-grid">
      {
        logos.map((logo) => (
          <div class="tool-item">
            <div class="tool-logo">
              <img
                src={`/logos/${logo.file}`}
                alt={logo.name}
                width="28"
                height="28"
                loading="lazy"
              />
            </div>
            <span class="tool-name">{logo.name}</span>
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .index-layout {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  @media (max-width: 768px) {
    .index-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* ── Bio ── */
  .index-bio {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--cv-text);
  }

  .index-bio p {
    margin-bottom: 1rem;
  }

  .index-bio strong {
    color: var(--cv-accent);
    font-weight: 600;
  }

  /* ── Tools ── */
  .index-tools {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .tools-title {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cv-text-muted);
    margin: 0 0 0.5rem;
  }

  .tools-grid {
    display: grid;
    /* Ajuste fluido inteligente: calcula cuántas columnas caben según el espacio disponible */
    grid-template-columns: repeat(auto-fill, minmax(64px, 1fr));
    gap: 1.2rem 0.8rem;
  }

  /* ── Tool item ── */
  .tool-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    cursor: default;
  }

  .tool-logo {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    /* Estilo base armonioso para Modo Claro */
    background: var(--cv-card-bg-alt, #f5f5f5);
    border: 1px solid var(--cv-border, #e6e6e6);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .tool-logo img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .tool-item:hover .tool-logo {
    transform: translateY(-3px);
    border-color: var(--cv-accent);
    box-shadow: 0 4px 10px var(--cv-shadow-sm, rgba(0, 0, 0, 0.05));
  }

  .tool-name {
    font-size: 0.65rem;
    color: var(--cv-text-muted);
    text-align: center;
    line-height: 1.2;
    transition: color 0.2s ease;
  }

  .tool-item:hover .tool-name {
    color: var(--cv-accent);
  }

  /* Modo Oscuro */
  [data-theme="dark"] .tool-logo {
    background: var(--cv-tag-bg, #1e2a3f);
    border-color: var(--cv-border, #1e3a5f);
  }

  [data-theme="dark"] .tool-logo img {
    filter: brightness(0.9);
  }
</style>
