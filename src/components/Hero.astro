---
import ImgUser from "../assets/3.png";
import { heroData } from "../data/hero";

const { pathname } = Astro.url;
const lang = pathname.startsWith("/en") ? "en" : "es";
const t = heroData[lang];

const heroConfig = {
  icons: {
    status: "fas fa-terminal",
    quote: "fas fa-quote-left",
  },
};
---

<div class="hero-layout">

  <!-- Foto: oculta en desktop via CSS, visible en tablet y móvil -->
  <div class="hero-photo">
    <figure class="image is-128x128">
      <img src={ImgUser.src} alt="Profile" class="is-rounded" />
    </figure>
  </div>

  <!-- Título y subtitle -->
  <div class="hero-title">
    <p class="title">{t.title}</p>
    <p class="subtitle">
      <span class="icon mr-2">
        <i class={heroConfig.icons.status}></i>
      </span>
      {t.subtitle}
    </p>
  </div>

  <!-- Cita y tags -->
  <div class="hero-quote">
    <article class="message">
      <div class="message-body">
        <div class="is-flex is-align-items-center">
          <span class="icon mr-2">
            <i class={heroConfig.icons.quote}></i>
          </span>
          <p set:html={t.message} />
        </div>
      </div>
    </article>
    <div class="tags">
      {t.tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
  </div>

</div>
