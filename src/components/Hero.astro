---
import { heroData } from "../data/hero";

const { pathname } = Astro.url;
const lang = pathname.startsWith("/en") ? "en" : "es";
const t = heroData[lang];

const heroConfig = {
  icons: {
    status: "fas fa-terminal",
    quote: "fas fa-quote-left",
  },
};
---

<div class="container">
  <div class="columns is-vcentered">
    <div class="column">
      <div class="content">
        <p class="title">{t.title}</p>
        <p class="subtitle">
          <span class="icon mr-2">
            <i class={heroConfig.icons.status}></i>
          </span>
          {t.subtitle}
        </p>
      </div>
    </div>

    <div class="column">
      <article class="message">
        <div class="message-body">
          <div class="is-flex is-align-items-center">
            <span class="icon mr-2">
              <i class={heroConfig.icons.quote}></i>
            </span>
            <p set:html={t.message} />
          </div>
        </div>
      </article>

      <div class="tags">
        {t.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    </div>
  </div>
</div>
