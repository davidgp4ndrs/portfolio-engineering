---
// src/components/Sidebar.astro
import ImgUser from "../assets/img.png";

const { pathname } = Astro.url;
const lang = pathname.startsWith("/en") ? "en" : "es";

const labels = {
  es: {
    role: "Ingeniero en Electrónica y Comunicaciones",
    availability: "Disponibilidad inmediata",
    nav: [
      { label: "Inicio", path: `/${lang}/`, icon: "fas fa-home" },
      {
        label: "Servicios",
        path: `/${lang}/services`,
        icon: "fas fa-broadcast-tower",
      },
      {
        label: "Proyectos",
        path: `/${lang}/experience`,
        icon: "fas fa-layer-group",
      },
      {
        label: "Competencias",
        path: `/${lang}/skills`,
        icon: "fas fa-terminal",
      },
      {
        label: "Contacto",
        path: `/${lang}/contact`,
        icon: "fas fa-paper-plane",
      },
    ],
  },
  en: {
    role: "Electronics & Communications Engineer",
    availability: "Immediate availability",
    nav: [
      { label: "Home", path: `/${lang}/`, icon: "fas fa-home" },
      {
        label: "Services",
        path: `/${lang}/services`,
        icon: "fas fa-broadcast-tower",
      },
      {
        label: "Projects",
        path: `/${lang}/experience`,
        icon: "fas fa-layer-group",
      },
      {
        label: "Competencies",
        path: `/${lang}/skills`,
        icon: "fas fa-terminal",
      },
      {
        label: "Contact",
        path: `/${lang}/contact`,
        icon: "fas fa-paper-plane",
      },
    ],
  },
};

const t = labels[lang];
const currentPath = pathname.replace(/\/$/, "") || `/${lang}`;
const isActive = (path: string) => {
  const target = path.replace(/\/$/, "") || `/${lang}`;
  return currentPath === target;
};
---

<!-- Profile -->
<div class="sb-profile">
  <figure class="sb-avatar">
    <img
      src={ImgUser.src}
      alt="Profile photo"
      width="88"
      height="88"
      loading="eager"
    />
  </figure>
  <p class="sb-name">David Andres Gavilanes</p>
  <p class="sb-role">{t.role}</p>
  <p class="sb-availability">
    <span class="sb-dot" aria-hidden="true"></span>
    {t.availability}
  </p>
</div>

<hr class="sb-divider" />

<!-- Navigation -->
<nav class="sb-nav" aria-label="Main navigation">
  <ul>
    {
      t.nav.map((item) => {
        const active = isActive(item.path);
        return (
          <li>
            <a
              href={item.path}
              class={`sb-link ${active ? "sb-link--active" : ""}`}
              aria-current={active ? "page" : undefined}
            >
              <span class="icon is-small" aria-hidden="true">
                <i class={item.icon} />
              </span>
              {item.label}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>
