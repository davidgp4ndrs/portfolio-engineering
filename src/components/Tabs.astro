---
// src/components/Tabs.astro
const { pathname } = Astro.url;
const lang = pathname.startsWith("/en") ? "en" : "es";

const labels = {
  es: [
    { label: "Inicio", path: `/${lang}/`, icon: "fas fa-home" },
    {
      label: "Servicios",
      path: `/${lang}/services`,
      icon: "fas fa-broadcast-tower",
    },
    {
      label: "Proyectos",
      path: `/${lang}/experience`,
      icon: "fas fa-layer-group",
    },
    { label: "Competencias", path: `/${lang}/skills`, icon: "fas fa-terminal" },
    { label: "Contacto", path: `/${lang}/contact`, icon: "fas fa-paper-plane" },
  ],
  en: [
    { label: "Home", path: `/${lang}/`, icon: "fas fa-home" },
    {
      label: "Services",
      path: `/${lang}/services`,
      icon: "fas fa-broadcast-tower",
    },
    {
      label: "Projects",
      path: `/${lang}/experience`,
      icon: "fas fa-layer-group",
    },
    { label: "Competencies", path: `/${lang}/skills`, icon: "fas fa-terminal" },
    { label: "Contact", path: `/${lang}/contact`, icon: "fas fa-paper-plane" },
  ],
};

const nav = labels[lang];
const currentPath = pathname.replace(/\/$/, "") || `/${lang}`;
const isActive = (path: string) => {
  const target = path.replace(/\/$/, "") || `/${lang}`;
  return currentPath === target;
};
---

<div class="tabs is-boxed is-fullwidth">
  <ul>
    {
      nav.map((item) => {
        const active = isActive(item.path);
        return (
          <li class={active ? "is-active" : ""}>
            <a href={item.path} aria-current={active ? "page" : undefined}>
              <span class="icon is-small" aria-hidden="true">
                <i class={item.icon} />
              </span>
              <span class="tb-label">{item.label}</span>
            </a>
          </li>
        );
      })
    }
  </ul>
</div>
