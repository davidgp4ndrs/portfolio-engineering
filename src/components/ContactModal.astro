---
import { modalLabels } from "../data/ui";

const { pathname } = Astro.url;
const lang = pathname.startsWith("/en") ? "en" : "es";

const t = modalLabels[lang as keyof typeof modalLabels] || modalLabels.es;
---

<div id="contact-modal" class="modal">
  <div class="modal-background"></div>
  <div class="modal-content">
    <div class="box">
      <div class="level is-mobile mb-5">
        <div class="level-left">
          <div class="level-item">
            <span class="icon mr-2">
              <i class="fas fa-envelope"></i>
            </span>
            <p class="has-text-weight-bold">{t.title}</p>
          </div>
        </div>
        <div class="level-right">
          <button class="delete close-modal" aria-label="close"></button>
        </div>
      </div>

      <form action="#" method="POST">
        <div class="field">
          <label class="label">{t.name}</label>
          <div class="control has-icons-left">
            <input
              class="input"
              type="text"
              name="name"
              placeholder={t.placeholderName}
              required
            />
            <span class="icon is-left"><i class="fas fa-user"></i></span>
          </div>
        </div>

        <div class="field">
          <label class="label">{t.email}</label>
          <div class="control has-icons-left">
            <input
              class="input"
              type="email"
              name="email"
              placeholder={t.placeholderEmail}
              required
            />
            <span class="icon is-left"><i class="fas fa-at"></i></span>
          </div>
        </div>

        <div class="field">
          <label class="label">{t.message}</label>
          <div class="control">
            <textarea
              class="textarea"
              name="message"
              rows="4"
              placeholder={t.placeholderMsg}
              required></textarea>
          </div>
        </div>

        <div class="field mt-5">
          <div class="control">
            <button type="submit" class="button is-link is-fullwidth">
              <span class="icon"><i class="fas fa-paper-plane"></i></span>
              <span>{t.send}</span>
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function setupModal() {
    const modal = document.getElementById("contact-modal");
    const openBtns = document.querySelectorAll(".open-contact");
    const closeBtns = document.querySelectorAll(".close-modal, .modal-background");

    if (!modal) return;

    openBtns.forEach((btn) => {
      (btn as HTMLElement).onclick = (e) => {
        e.preventDefault();
        modal.classList.add("is-active");
        document.documentElement.classList.add("is-clipped");
      };
    });

    closeBtns.forEach((btn) => {
      (btn as HTMLElement).onclick = () => {
        modal.classList.remove("is-active");
        document.documentElement.classList.remove("is-clipped");
      };
    });
  }

  setupModal();
  document.addEventListener("astro:after-swap", setupModal);
</script>
