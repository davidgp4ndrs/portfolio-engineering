---
// src/components/SkillGrid.astro
import { skillsData } from "../data/skillsData";

const { pathname } = Astro.url;
const lang = pathname.startsWith("/en") ? "en" : "es";
const data = skillsData[lang];
---

<div class="sk-grid">
  {data.groups.map((group: any) => (
    <div class="sk-card">

      <!-- Category title -->
      <p class="sk-category">{group.category}</p>

      <!-- Two columns: detail + list -->
      <div class="sk-body">

        <!-- Left: detail -->
        <p class="sk-detail">{group.detail}</p>

        <!-- Right: skills list (Limitada a un máximo de 7 elementos) -->
        <ul class="sk-list">
          {group.skills.slice(0, 7).map((skill: string) => (
            <li class="sk-item">
              <span class="sk-dot" aria-hidden="true">·</span>
              {skill}
            </li>
          ))}
        </ul>

      </div>
    </div>
  ))}
</div>
