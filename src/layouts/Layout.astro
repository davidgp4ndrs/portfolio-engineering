---
import { ClientRouter } from "astro:transitions";
import Sidebar from "../components/Sidebar.astro";
import Hero from "../components/Hero.astro";
import Tabs from "../components/Tabs.astro";

import "@fontsource/dm-sans/400.css";
import "@fontsource/dm-sans/500.css";
import "@fontsource/dm-sans/700.css";
import "bulma/css/bulma.min.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const { pathname } = Astro.url;
const lang = pathname.startsWith("/en") ? "en" : "es";

const navItems = {
  es: [
    { label: "Inicio", path: `/${lang}/`, icon: "fas fa-home" },
    {
      label: "Servicios",
      path: `/${lang}/services`,
      icon: "fas fa-broadcast-tower",
    },
    {
      label: "Proyectos",
      path: `/${lang}/experience`,
      icon: "fas fa-layer-group",
    },
    { label: "Competencias", path: `/${lang}/skills`, icon: "fas fa-terminal" },
    { label: "Contacto", path: `/${lang}/contact`, icon: "fas fa-paper-plane" },
  ],
  en: [
    { label: "Home", path: `/${lang}/`, icon: "fas fa-home" },
    {
      label: "Services",
      path: `/${lang}/services`,
      icon: "fas fa-broadcast-tower",
    },
    {
      label: "Projects",
      path: `/${lang}/experience`,
      icon: "fas fa-layer-group",
    },
    { label: "Competencies", path: `/${lang}/skills`, icon: "fas fa-terminal" },
    { label: "Contact", path: `/${lang}/contact`, icon: "fas fa-paper-plane" },
  ],
};

const nav = navItems[lang];
const currentPath = pathname.replace(/\/$/, "") || `/${lang}`;
const isActive = (path: string) => {
  const target = path.replace(/\/$/, "") || `/${lang}`;
  return currentPath === target;
};
---

<!doctype html>
<html lang={lang} data-theme="light" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/icons/font/css/all.css" />
    <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/sidebar.css" />
    <link rel="stylesheet" href="/css/hero.css" />
    <link rel="stylesheet" href="/css/services.css" />
    <link rel="stylesheet" href="/css/projects.css" />
    <link rel="stylesheet" href="/css/skills.css" />
    <link rel="stylesheet" href="/css/mobile.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <title>{title}</title>
    <ClientRouter />

    <script is:inline>
      document.documentElement.classList.remove("no-js");
      const t =
        localStorage.getItem("theme") ||
        (window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light");
      document.documentElement.setAttribute("data-theme", t);
      document.addEventListener("astro:after-swap", () => {
        document.documentElement.classList.remove("no-js");
        document.documentElement.setAttribute(
          "data-theme",
          localStorage.getItem("theme") || "light",
        );
      });
    </script>
  </head>

  <body>
    <main class="section">
      <div class="container is-widescreen" style="max-width: 1100px;">
        <div class="card">
          <!-- Window chrome -->
          <header class="card-header">
            <div class="card-header-title">
              <span class="win-dot win-dot--close" aria-hidden="true"></span>
              <span class="win-dot win-dot--minimize" aria-hidden="true"></span>
              <span class="win-dot win-dot--maximize" aria-hidden="true"></span>
              <small class="win-title">{title}.exe</small>
            </div>
            <div class="header-controls">
              <button
                id="lang-toggle"
                class="ctrl-btn"
                aria-label="Toggle language">ES</button
              >
              <button
                id="theme-toggle"
                class="ctrl-btn"
                aria-label="Toggle theme"
              >
                <span class="icon is-small">
                  <i class="fas fa-sun" id="theme-icon"></i>
                </span>
              </button>
            </div>
          </header>

          <!-- Content -->
          <div class="card-content p-0">
            <div class="app-columns">
              <!-- Sidebar — desktop only -->
              <aside
                class="sidebar-wrapper"
                id="sidebar"
                aria-label="Navigation"
              >
                <Sidebar />
              </aside>

              <!-- Main -->
              <div class="content-column">
                <!-- Hero -->
                <div class="hero is-small">
                  <div class="hero-body">
                    <Hero />
                  </div>
                </div>

                <!-- Tabs — tablet + mobile -->
                <div class="hero-tab">
                  <Tabs />
                </div>

                <!-- Desktop divider — only when tabs hidden -->
                <div class="desktop-divider"></div>

                <!-- Content -->
                <div class="content-scroll">
                  <slot />
                </div>
              </div>
            </div>
          </div>

          <!-- Footer -->
          <footer class="card-footer">
            <div class="card-footer-item">
              <span class="is-size-7">Status: <strong>Online</strong></span>
            </div>
            <div class="card-footer-item">
              <span class="is-size-7"> Leon · <strong>España</strong></span>
            </div>
          </footer>
        </div>
      </div>
    </main>

    <script src="/js/theme.js" is:inline></script>
    <script src="/js/lang.js" is:inline></script>
  </body>
</html>
