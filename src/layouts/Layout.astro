---
import "bulma/css/bulma.min.css";
import Sidebar from "../components/Sidebar.astro";
import Hero from "../components/Hero.astro";
import Tabs from "../components/Tabs.astro";

interface Props {
  title: string;
}
const { title } = Astro.props;

// Configuración de iconos de la "ventana"
const winIcons = {
  close: "fa-solid fa-circle has-text-danger",
  minimize: "fa-solid fa-circle has-text-warning",
  maximize: "fa-solid fa-circle has-text-success",
  options: "fas fa-angle-down",
};
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/icons/font/css/all.css" />
    <link rel="stylesheet" href="/css/debug.css" />
    <title>{title}</title>
  </head>
  <body>
    <main class="section is-small">
      <div class="container is-fullhd">
        <div class="card">
          <header class="card-header">
            <div class="card-header-title">
              <span class="icon is-small mx-1"
                ><i class={winIcons.close}></i></span
              >
              <span class="icon is-small mx-1"
                ><i class={winIcons.minimize}></i></span
              >
              <span class="icon is-small mx-1"
                ><i class={winIcons.maximize}></i></span
              >
              <small class="ml-3 has-text-grey">{title}.exe</small>
            </div>
            <button class="card-header-icon">
              <span class="icon">
                <i class={winIcons.options}></i>
              </span>
            </button>
          </header>

          <div class="card-content">
            <div class="columns is-gapless">
              <aside class="column is-3">
                <Sidebar />
              </aside>

              <div class="column is-9">
                <header class="hero is-small">
                  <div class="hero-body">
                    <Hero />
                  </div>
                  <div class="hero-foot">
                    <Tabs />
                  </div>
                </header>

                <div class="section">
                  <slot />
                </div>
              </div>
            </div>
          </div>

          <footer class="card-footer">
            <div class="card-footer-item">
              <span class="is-size-7">
                Lorem Ipsum: <strong>Online</strong>
              </span>
            </div>
            <div class="card-footer-item">
              <a href="#" class="is-size-7">
                <span class="icon"><i class="fab fa-github"></i></span>
                Lorem Source
              </a>
            </div>
          </footer>
        </div>
      </div>
    </main>
  </body>
</html>
