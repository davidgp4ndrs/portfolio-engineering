---
import Layout from "../layouts/Layout.astro";

// Configuración centralizada de iconos y datos de relleno
const uiConfig = {
  headerIcon: "fas fa-layer-group",
  serviceIcon: "fas fa-circle",
  quoteIcon: "fas fa-quote-left",
  infoIcon: "fas fa-info-circle",
};

const services = [
  {
    title: "Lorem Ipsum Dolor",
    description:
      "Consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore.",
    items: ["Lorem Item 1", "Lorem Item 2", "Lorem Item 3"],
  },
  {
    title: "Sit Amet Consectetur",
    description:
      "Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi.",
    items: ["Lorem Item A", "Lorem Item B", "Lorem Item C"],
  },
  {
    title: "Adipiscing Elit Sed",
    description:
      "Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore.",
    items: ["Lorem Item X", "Lorem Item Y", "Lorem Item Z"],
  },
];
---

<Layout title="Lorem Ipsum | Services">
  <div class="container mb-5 mt-0">
    <div class="is-flex is-align-items-center">
      <span class="icon mr-2">
        <i class={uiConfig.headerIcon}></i>
      </span>
      <h2 class="title">Lorem Ipsum Services</h2>
    </div>
  </div>

  <div class="container">
    <div class="columns is-multiline">
      {
        services.map((service) => (
          <div class="column is-4">
            <article class="media">
              <figure class="media-left">
                <span class="icon">
                  <i class={uiConfig.serviceIcon} />
                </span>
              </figure>
              <div class="media-content">
                <div class="content">
                  <p>
                    <strong>{service.title}</strong>
                    <br />
                    <small>{service.description}</small>
                  </p>
                  <ul>
                    {service.items.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>
              </div>
            </article>
          </div>
        ))
      }

      <div class="column is-12">
        <article class="message">
          <div class="message-body">
            <div class="is-flex is-align-items-center">
              <span class="icon mr-2">
                <i class={uiConfig.quoteIcon}></i>
              </span>
              <p>
                Lorem ipsum dolor sit amet, consectetur adipiscing elit.
                <code>lorem_ipsum</code> elementum.
              </p>
            </div>
          </div>
        </article>
      </div>
    </div>
  </div>
</Layout>
