---
import Layout from "../layouts/Layout.astro";

// Configuración centralizada para iconos
const skillConfig = {
  headerIcon: "fas fa-layer-group",
  categoryIcon: "fas fa-circle-notch",
};

const skillGroups = [
  {
    category: "Lorem Ipsum 1",
    skills: ["Lorem", "Ipsum", "Dolor"],
    status: "STATUS_A",
  },
  {
    category: "Lorem Ipsum 2",
    skills: ["Sit", "Amet", "Consectetur"],
    status: "STATUS_B",
  },
  {
    category: "Lorem Ipsum 3",
    skills: ["Adipiscing", "Elit", "Sed"],
    status: "STATUS_C",
  },
];
---

<Layout title="Lorem Ipsum | Skills">
  <div class="container mb-5">
    <div class="is-flex is-align-items-center">
      <span class="icon mr-2">
        <i class={skillConfig.headerIcon}></i>
      </span>
      <h2 class="title">Lorem Ipsum Stack</h2>
    </div>
  </div>

  <div class="container">
    <div class="columns is-multiline">
      {
        skillGroups.map((group) => (
          <div class="column is-4">
            <div class="box">
              <div class="level is-mobile mb-3">
                <div class="level-left">
                  <span class="icon is-small mr-2">
                    <i class={skillConfig.categoryIcon} />
                  </span>
                  <p class="heading mb-0">{group.category}</p>
                </div>
                <div class="level-right">
                  <span class="tag is-light">{group.status}</span>
                </div>
              </div>

              <div class="tags">
                {group.skills.map((skill) => (
                  <span class="tag">{skill}</span>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <div class="container mt-4">
      <p class="is-size-7 has-text-centered">
        Lorem ipsum dolor sit amet: <strong>LOREM_DATA_IPSUM</strong>
      </p>
    </div>
  </div>
</Layout>
