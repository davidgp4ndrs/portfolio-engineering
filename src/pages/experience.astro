---
import Layout from "../layouts/Layout.astro";

// Configuración centralizada
const projectConfig = {
  sectionIcon: "fas fa-clipboard-list",
  noteIcon: "fas fa-check-double",
};

const projects = [
  {
    role: "Lorem Ipsum Role",
    title: "Project Lorem One",
    period: "0000 - 0000",
    description:
      "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.",
    tags: ["Lorem", "Ipsum", "Dolor"],
  },
  {
    role: "Lorem Ipsum Role",
    title: "Project Lorem Two",
    period: "0000 - 0000",
    description:
      "Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.",
    tags: ["Sit", "Amet", "Consectetur"],
  },
  {
    role: "Lorem Ipsum Role",
    title: "Project Lorem Three",
    period: "0000 - 0000",
    description:
      "Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.",
    tags: ["Adipiscing", "Elit", "Sed"],
  },
];
---

<Layout title="Lorem Ipsum | Projects">
  <div class="container mb-5">
    <div class="is-flex is-align-items-center">
      <span class="icon mr-2">
        <i class={projectConfig.sectionIcon}></i>
      </span>
      <h2 class="title">Lorem Ipsum Log</h2>
      <span class="tag ml-3">v.0.0.0</span>
    </div>
  </div>

  <div class="container">
    <div class="columns is-multiline">
      {
        projects.map((item) => (
          <div class="column is-4">
            <article class="media">
              <div class="media-content">
                <div class="content">
                  <div class="is-flex is-justify-content-space-between">
                    <h3 class="title">{item.title}</h3>
                    <span class="tag is-light">{item.period}</span>
                  </div>
                  <p class="subtitle">{item.role}</p>
                  <p>{item.description}</p>
                  <div class="tags">
                    {item.tags.map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                </div>
              </div>
            </article>
          </div>
        ))
      }
    </div>

    <div class="container mt-3">
      <div class="is-flex is-justify-content-flex-end">
        <div class="content">
          <p class="is-size-7">
            <span class="icon is-small">
              <i class={projectConfig.noteIcon}></i>
            </span>
            Lorem ipsum dolor sit amet: <strong>CONSECTETUR</strong>
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>
